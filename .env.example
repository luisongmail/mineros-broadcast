# Variables de entorno requeridas
# Copiar a apps/studio/.env y completar (NUNCA commitear .env)

# ═══════════════════════════════════════════════════════════════════════════════
# PUERTOS DEL SISTEMA (fijos — no cambiar sin actualizar todos los archivos)
# ═══════════════════════════════════════════════════════════════════════════════
#
#  :3001  →  Express API + WebSocket (dev local)
#  :5173  →  Vite dev server (UI con hot-reload) → accede aquí en desarrollo
#  :3306  →  MySQL (Docker)
#  :8080  →  PlayFlow Studio completo (Docker producción)
#
#  Dev local:  pnpm dev:full   → http://localhost:5173/control
#  Docker:     docker compose up -d  → http://localhost:8080/control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Base de datos MySQL ─────────────────────────────────────────────────────
# Formato: mysql://{user}:{password}@{host}:{port}/{database}
# Local con Docker Compose:
DATABASE_URL=mysql://playflow_app:dev_password@localhost:3306/playflow_db
# Producción Azure:
# DATABASE_URL=mysql://playflow_app:***@playflow-db.mysql.database.azure.com:3306/playflow_db

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001                          # En Docker usar 8080
NODE_ENV=development               # En Docker: production

# ─── CORS (opcional, para acceso remoto) ─────────────────────────────────────
# ALLOWED_ORIGIN=https://broadcast-overlays.azurestaticapps.net

# ─── Docker ──────────────────────────────────────────────────────────────────
HOST_PORT=8080                     # Puerto expuesto en la máquina anfitriona

# ─── Vite (frontend) — solo para dev ─────────────────────────────────────────
# En Docker no se necesitan; el servidor las resuelve automáticamente
# VITE_WS_URL=ws://localhost:3001
# VITE_API_URL=http://localhost:3001/api
