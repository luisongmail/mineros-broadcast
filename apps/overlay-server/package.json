{
  "name": "@playflow/overlay-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Servidor de overlays y backend OTP básico para PlayFlow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
