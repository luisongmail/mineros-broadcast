    "mysql2": "^3.9.0",
    "ws": "^8.16.0",
    "@supabase/supabase-js": "^2.54.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "*"
  }
}
