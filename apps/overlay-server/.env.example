# Variables mínimas para apps/overlay-server
# Copiar a apps/overlay-server/.env o exportar en el entorno.

PORT=3001
DATABASE_URL=mysql://playflow_app:dev_password@localhost:3306/playflow_db
JWT_SECRET=playflow-overlay-server-dev-secret
JWT_ISSUER=playflow
JWT_AUDIENCE=playflow-app
JWT_ACCESS_TOKEN_SECONDS=900
OTP_TTL_MINUTES=10

# Supabase Realtime para snapshots autoritativos.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-service-role-o-anon-key
