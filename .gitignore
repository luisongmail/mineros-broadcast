# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Node / pnpm
node_modules/
dist/
.turbo/
*.tsbuildinfo

# Env
.env
.env.local
.env.*.local

# Vercel
.vercel/

# Supabase
.supabase/

# OS
.DS_Store

# Assets locales — binarios no se commitean, subirlos a Azure en producción
apps/overlay-server/storage/assets/**/*.jpg
apps/overlay-server/storage/assets/**/*.jpeg
apps/overlay-server/storage/assets/**/*.png
apps/overlay-server/storage/assets/**/*.gif
apps/overlay-server/storage/assets/**/*.svg
apps/overlay-server/storage/assets/**/*.webp
# Excepto los .keep (estructura de carpetas)
!apps/overlay-server/storage/assets/**/.keep

# Backups de BD
infra/*.sql
*.sql
